import "./util.jou"


def main() -> int:
    run_himmeli("--loop")               # Output: ./himmeli: missing time after --loop (try --help)
    run_himmeli("--loop asd")           # Output: ./himmeli: invalid loop time "asd", try e.g. 3min or 1h
    run_himmeli("--loop=asd")           # Output: ./himmeli: invalid loop time "asd", try e.g. 3min or 1h
    run_himmeli("--loop ''")            # Output: ./himmeli: invalid loop time "", try e.g. 3min or 1h
    run_himmeli("--loop=")              # Output: ./himmeli: invalid loop time "", try e.g. 3min or 1h
    run_himmeli("--loop h")             # Output: ./himmeli: invalid loop time "h", try e.g. 3min or 1h
    run_himmeli("--loop=h")             # Output: ./himmeli: invalid loop time "h", try e.g. 3min or 1h
    run_himmeli("--loop 123123123123123123h")  # Output: ./himmeli: invalid loop time "123123123123123123h", try e.g. 3min or 1h
    run_himmeli("--loop=123123123123123123h")  # Output: ./himmeli: invalid loop time "123123123123123123h", try e.g. 3min or 1h
    run_himmeli("--loop 3")             # Output: ./himmeli: missing time unit in loop time "3", try e.g. 3min or 1h
    run_himmeli("--loop=3")             # Output: ./himmeli: missing time unit in loop time "3", try e.g. 3min or 1h
    run_himmeli("--loop '0 minutes'")   # Output: ./himmeli: loop time cannot be zero
    run_himmeli("--loop '0 hours'")     # Output: ./himmeli: loop time cannot be zero
    run_himmeli("--loop 1s")            # Output: ./himmeli: specifying loop time in seconds is not supported, use minutes or hours
    run_himmeli("--loop '1 sec'")       # Output: ./himmeli: specifying loop time in seconds is not supported, use minutes or hours
    run_himmeli("--loop 1second")       # Output: ./himmeli: specifying loop time in seconds is not supported, use minutes or hours
    run_himmeli("--loop '1 seconds'")   # Output: ./himmeli: specifying loop time in seconds is not supported, use minutes or hours

    setenv("HIMMELI_OVERRIDE_TIME", "01:00", True as int)

    # Output: Would immediately apply visibility value 1.00.
    # Output: Then wait 1 minute (until 01:01).
    # Output: Then adjust again: apply visibility value 0.98.
    # Output: Then wait 1 minute (until 01:02).
    # Output: Then adjust again: apply visibility value 0.96.
    # Output: Then wait 1 minute (until 01:03).
    # Output: Then adjust again: apply visibility value 0.94.
    # Output: Then wait 1 minute (until 01:04).
    # Output: Then adjust again: apply visibility value 0.92.
    # Output: And so on.
    run_himmeli("--loop '1 min' '1 @ 1' '0.4 @ 1:30'")

    # Output: Would immediately apply visibility value 1.00.
    # Output: Then wait 5 minutes (until 01:05).
    # Output: Then adjust again: apply visibility value 0.90.
    # Output: Then wait 5 minutes (until 01:10).
    # Output: Then adjust again: apply visibility value 0.80.
    # Output: Then wait 5 minutes (until 01:15).
    # Output: Then adjust again: apply visibility value 0.70.
    # Output: Then wait 5 minutes (until 01:20).
    # Output: Then adjust again: apply visibility value 0.60.
    # Output: And so on.
    run_himmeli("--loop '5 minutes' '1 @ 1' '0.4 @ 1:30'")

    # Output: Would immediately apply visibility value 0.40.
    # Output: Then wait 1 hour and 30 minutes (until 02:30).
    # Output: Then adjust again: apply visibility value 0.50.
    # Output: Then wait 1 hour and 30 minutes (until 04:00).
    # Output: Then adjust again: apply visibility value 0.60.
    # Output: Then wait 1 hour and 30 minutes (until 05:30).
    # Output: Then adjust again: apply visibility value 0.70.
    # Output: Then wait 1 hour and 30 minutes (until 07:00).
    # Output: Then adjust again: apply visibility value 0.80.
    # Output: And so on.
    run_himmeli("--loop 90min '0.4 @ 1' '0.8 @ 7'")

    # Output: Would immediately multiply red by 0.80, green by 0.40 and blue by 0.00.
    # Output: Then wait 2 hours (until 03:00).
    # Output: Then adjust again: multiply red by 0.85, green by 0.55 and blue by 0.15.
    # Output: Then wait 2 hours (until 05:00).
    # Output: Then adjust again: multiply red by 0.90, green by 0.70 and blue by 0.30.
    # Output: Then wait 2 hours (until 07:00).
    # Output: Then adjust again: multiply red by 0.95, green by 0.85 and blue by 0.45.
    # Output: Then wait 2 hours (until 09:00).
    # Output: Then adjust again: multiply red by 1.00, green by 1.00 and blue by 0.60.
    # Output: And so on.
    run_himmeli("--loop=2h '0.8 0.4 0 @ 1' '1 1 0.6 @ 9'")

    return 0
