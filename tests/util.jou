import "stdlib/io.jou"
import "stdlib/str.jou"
import "stdlib/process.jou"

# TODO(Jou): add these to stdlib?
@public
declare setenv(name: byte*, value: byte*, overwrite: int) -> int
@public
declare unsetenv(name: byte*) -> int

@public
def run_himmeli(args: byte*) -> None:
    # Make sure that prints appear in the correct order with system() output.
    # The output from a subprocess is basically flushed implicitly.
    fflush(get_stdout())
    fflush(get_stderr())

    # Tests are always invoked through --dry-run, so there should be no way for
    # them to actually adjust your screens.
    full_command: byte[1024]
    snprintf(full_command, sizeof(full_command), "./himmeli --dry-run %s", args)
    system(full_command)
