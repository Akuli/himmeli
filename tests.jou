import "stdlib/process.jou"
import "stdlib/str.jou"
import "stdlib/io.jou"

declare setenv(name: byte*, value: byte*, overwrite: int) -> int
declare unsetenv(name: byte*) -> int


def run_himmeli(args: byte*) -> None:
    # Make sure that prints appear in the correct order with system() output
    fflush(get_stdout())

    # Tests are always invoked through --dry-run, so there should be no way for
    # them to actually adjust your screens.
    full_command: byte[1024]
    snprintf(full_command, sizeof(full_command), "./himmeli --dry-run %s", args)
    system(full_command)


def test_help() -> None:
    # Output: Usage:
    # Output:   ./himmeli [options] "STATE"
    # Output:   ./himmeli [options] "STATE1 @ hh:mm" "STATE2 @ hh:mm" ...
    # Output:
    # Output: Options:
    # Output:   --help           this message
    # Output:   --allow-dark     allow making the screen very dark
    # Output:   --loop INTERVAL  adjust, wait, adjust again etc, INTERVAL is e.g. 5min or 1h
    # Output:   --dry-run        don't adjust screens, describe what would be done
    # Output:
    # Output: The simplest way to specify a state is a number between 0 and 1. Here 0 means
    # Output: black screen, 1 means reset, and values between 0 and 1 filter out mostly blue
    # Output: light. For example, I use 0.6 during the day to make the screen look comfy and
    # Output: easy on my eyes.
    # Output:
    # Output: The state can also be R, G and B numbers between 0 and 1 separated by spaces.
    # Output: For example, "0.5 0.5 0.5" basically decreases brightness, and "1 1 0" filters
    # Output: out all blue light (probably not what you want).
    # Output:
    # Output: If you specify multiple states, they must have "@ hh:mm" (hour and minute) or
    # Output: "@ hh" (hour) at the end to specify when the state should apply: "0.6 @ 22"
    # Output: means that value 0.6 will be used if you run the command at 22:00 (10PM). The
    # Output: values are interpolated at other times (linearly by default).
    run_himmeli("--help")
    puts("")  # Output:


def test_bad_states() -> None:
    puts("Bad states")              # Output: Bad states
    run_himmeli("''")               # Output: ./himmeli: invalid state "" (try --help)
    run_himmeli("'1 1'")            # Output: ./himmeli: invalid state "1 1" (try --help)
    run_himmeli("'1 1 1 1'")        # Output: ./himmeli: invalid state "1 1 1 1" (try --help)
    run_himmeli("'1 1 1 1 1'")      # Output: ./himmeli: invalid state "1 1 1 1 1" (try --help)
    run_himmeli("inf")              # Output: ./himmeli: invalid state "inf" (try --help)
    run_himmeli("nan")              # Output: ./himmeli: invalid state "nan" (try --help)
    run_himmeli("' -0.5'")          # Output: ./himmeli: invalid state "-0.5" (try --help)
    run_himmeli("5")                # Output: ./himmeli: invalid state "5" (try --help)
    run_himmeli("'1 1 -0.5'")       # Output: ./himmeli: invalid state "1 1 -0.5" (try --help)
    run_himmeli("'1 1 5'")          # Output: ./himmeli: invalid state "1 1 5" (try --help)
    run_himmeli("'5 @ 12:34'")      # Output: ./himmeli: invalid state "5" (try --help)
    run_himmeli("'1 1 5 @ 12:34'")  # Output: ./himmeli: invalid state "1 1 5" (try --help)
    puts("")                        # Output:


def test_totally_wrong_arguments() -> None:
    puts("Totally wrong arguments") # Output: Totally wrong arguments
    run_himmeli("")                 # Output: ./himmeli: please specify how to color the screen (try --help)
    run_himmeli("-1")               # Output: ./himmeli: unknown option "-1" (try --help)
    run_himmeli("--asdf")           # Output: ./himmeli: unknown option "--asdf" (try --help)
    puts("")                        # Output:


def test_specifying_bad_time() -> None:
    puts("Specifying bad time")                 # Output: Specifying bad time
    run_himmeli("1 '1 @ 12:34'")                # Output: ./himmeli: when you specify multiple states, you must use '@' to specify a time for each state
    run_himmeli("1 '1 @ 12:34' '0.5 @ 23:45'")  # Output: ./himmeli: when you specify multiple states, you must use '@' to specify a time for each state
    run_himmeli("'1 @ 12:34'")                  # Output: ./himmeli: a time cannot be specified if you give just one state (try --help)
    run_himmeli("'1 1 1 @ 12:34'")              # Output: ./himmeli: a time cannot be specified if you give just one state (try --help)
    run_himmeli("'1 @ 12:34' '0.5 @ 23:78'")    # Output: ./himmeli: invalid time "23:78" (try --help)
    run_himmeli("'1 @ 12:34' '0.5 @ -1:05'")    # Output: ./himmeli: invalid time "-1:05" (try --help)
    run_himmeli("'1 @ 12:34' '0.5 @ 5:-1'")     # Output: ./himmeli: invalid time "5:-1" (try --help)
    run_himmeli("'1 @ 12:34' '0.5 @ 23 :45'")   # Output: ./himmeli: invalid time "23 :45" (try --help)
    run_himmeli("'1 @ 12:34' '0.5 @ 12:34:56'") # Output: ./himmeli: invalid time "12:34:56" (try --help)

    run_himmeli("'0.5 @ 01:00' '0.6 @ 01:00'")                # Output: ./himmeli: the time 01:00 cannot be specified twice
    run_himmeli("'0.5 @ 12:34' '0.6 @ 01:00' '0.7 @ 12:34'")  # Output: ./himmeli: the time 12:34 cannot be specified twice

    puts("")  # Output:


def test_specifying_time_correctly() -> None:
    puts("Specifying time correctly")   # Output: Specifying time correctly

    # Output: Would multiply red by 1.00, green by 1.00 and blue by 1.00.
    setenv("HIMMELI_OVERRIDE_TIME", "12:34", True as int)
    run_himmeli("'  1 1   1@12:34' '.6@   23:45 '")

    # Time is not octal when it has a leading zero, so 09 is allowed.
    # Output: Would multiply red by 0.75, green by 0.75 and blue by 0.75.
    setenv("HIMMELI_OVERRIDE_TIME", "9:00", True as int)
    run_himmeli("'0.5 0.5 0.5 @ 8:59 ' '1 1 1 @ 09:01'")

    unsetenv("HIMMELI_OVERRIDE_TIME")
    puts("")  # Output:


def test_simple_and_correct() -> None:
    puts("Simple and correct")  # Output: Simple and correct
    run_himmeli("0.2")  # Output: Would multiply red by 1.00, green by 0.23 and blue by 0.02.
    run_himmeli("0.4")  # Output: Would multiply red by 1.00, green by 0.57 and blue by 0.21.
    run_himmeli("0.6")  # Output: Would multiply red by 1.00, green by 0.76 and blue by 0.60.
    run_himmeli("0.8")  # Output: Would multiply red by 1.00, green by 0.86 and blue by 0.87.
    run_himmeli("1")    # Output: Would multiply red by 1.00, green by 1.00 and blue by 1.00.
    puts("")            # Output:


def test_allow_dark() -> None:
    puts("The --allow-dark flag")  # Output: The --allow-dark flag

    # Flag missing
    run_himmeli("0.01")  # Output: ./himmeli: refusing because \"0.01\" would make the screen very dark, use --allow-dark if that's really what you want
    run_himmeli("'0.01 @ 12:34' '1 @ 23:45'")  # Output: ./himmeli: refusing because \"0.01\" would make the screen very dark, use --allow-dark if that's really what you want
    run_himmeli("'1 @ 12:34' '0.01 @ 23:45'")  # Output: ./himmeli: refusing because \"0.01\" would make the screen very dark, use --allow-dark if that's really what you want

    # Flag given as needed
    run_himmeli("0.01 --allow-dark")  # Output: Would multiply red by 0.07, green by 0.00 and blue by 0.00.

    setenv("HIMMELI_OVERRIDE_TIME", "11:11", True as int)
    run_himmeli("--allow-dark '0.01 @ 12:34' '1 @ 23:45'")  # Output: Would multiply red by 0.78, green by 0.10 and blue by 0.00.
    run_himmeli("--allow-dark '1 @ 12:34' '0.01 @ 23:45'")  # Output: Would multiply red by 1.00, green by 0.91 and blue by 0.95.
    unsetenv("HIMMELI_OVERRIDE_TIME")

    # These should not trigger the --allow-dark mechanism
    run_himmeli("'1 0 0'")  # Output: Would multiply red by 1.00, green by 0.00 and blue by 0.00.
    run_himmeli("'0 1 0'")  # Output: Would multiply red by 0.00, green by 1.00 and blue by 0.00.
    run_himmeli("'0 0 1'")  # Output: Would multiply red by 0.00, green by 0.00 and blue by 1.00.

    puts("")    # Output:


def main() -> int:
    if system("jou -o himmeli src/main.jou") != 0:
        exit(1)

    test_help()
    test_bad_states()
    test_totally_wrong_arguments()
    test_specifying_bad_time()
    test_specifying_time_correctly()
    test_simple_and_correct()
    test_allow_dark()

    return 0


